# =============================================================================
#  Défauts GNOME de la flotte — base dconf « local ».
#  Compilé par `dconf update` au build (voir build_files/build.sh).
#  NON verrouillés : l'utilisateur peut les modifier. Pour imposer une valeur, créer
#  /etc/dconf/db/local.d/locks/<nom> listant les clés à verrouiller (voir docs/04).
# =============================================================================

[org/gnome/shell]
# Active l'extension AppIndicator / KStatusNotifierItem (zone de notification).
# Indispensable au tray de kDrive (client Qt) et utile à d'autres apps.
# UUID vérifié dans le metadata.json de l'extension.
enabled-extensions=['appindicatorsupport@rgcjonas.gmail.com']

[org/gnome/desktop/input-sources]
# Flotte bilingue DE-CH / FR-CH : les deux dispositions clavier suisses sont
# disponibles pour tous, basculables depuis la barre du haut (indicateur fr|de).
# Non verrouillé : chacun peut réordonner / en retirer. La 1re est utilisée par défaut.
sources=[('xkb', 'ch+fr'), ('xkb', 'ch')]

[org/gnome/desktop/background]
# Fond d'écran de la flotte : variante claire/sombre selon le thème de l'utilisateur.
picture-uri='file:///usr/share/backgrounds/szh/szh-wallpaper-light.png'
picture-uri-dark='file:///usr/share/backgrounds/szh/szh-wallpaper-dark.png'
# 'zoom' = l'image remplit l'écran (cover), léger rognage si l'écran n'est pas 16:9.
# Les fonds szh sont en 16:9 (3840×2160) avec marges autour du logo → rognage sûr sur
# 16:10 (ThinkPad X13 1920×1200). On évite 'scaled' : avec une seule primary-color
# partagée, il mettrait des bandes bleu nuit autour de l'image CLAIRE (moche).
picture-options='zoom'
primary-color='#252b46'

[org/gnome/desktop/screensaver]
# Écran de verrouillage : variante sombre.
picture-uri='file:///usr/share/backgrounds/szh/szh-wallpaper-dark.png'
picture-options='zoom'
primary-color='#252b46'
