#!/usr/bin/env bash
# =============================================================================
#  fleet-rotate-secrets — moteur de post-installation de la flotte SZH/CSPS.
#  Lancé via ~admin/post-install.sh. Étapes (en root) :
#    1. enrôle le TPM2 (déverrouillage auto LUKS) s'il ne l'est pas (sauf --notpm) ;
#    2. ajoute une nouvelle passphrase LUKS, puis retire l'amorçage « changeme » ;
#    3. change le mot de passe « admin » (+ réinitialise son trousseau) ;
#    4. active la régénération locale de l'initramfs (splash szh + clavier suisse LUKS).
#  Sortie écran : seulement OK / KO / WARN ; le détail va dans un journal.
# =============================================================================
set -uo pipefail

BOOTSTRAP_PASS="changeme"
ADMIN_USER="admin"
NEW_LUKS_PASS=""
NEW_ADMIN_PASS=""
NO_TPM=0
ENROLL_ONLY=0
INITRAMFS_SERVICE="fleet-initramfs-localize.service"
INITRAMFS_STAMP="/var/lib/fleet/initramfs-localized"

usage() {
    cat <<'USAGE'
Usage : post-install.sh [options]

Post-installation SZH/CSPS (à lancer une fois, en admin) :
  - enrôle le TPM2 (déverrouillage auto LUKS) s'il ne l'est pas déjà ;
  - ajoute une nouvelle passphrase LUKS et retire l'amorçage « changeme » ;
  - change le mot de passe du compte « admin » (+ réinitialise son trousseau) ;
  - active la régénération locale de l'initramfs (splash + clavier suisse au boot).

Options :
  --luks=VALEUR     Nouvelle passphrase LUKS. Absent  -> demandée interactivement.
  --admin=VALEUR    Nouveau mot de passe admin. Absent -> demandé interactivement.
  --enrolltpm       Enrôle UNIQUEMENT le TPM, puis sort.
  --notpm           Ne PAS toucher au TPM.
  -h, --help        Affiche cette aide.

Exemples :
  ./post-install.sh
  ./post-install.sh --luks=MaPhraseLUKS --admin=MonMotDePasse
  ./post-install.sh --enrolltpm

La sortie écran reste minimale ; le détail complet est écrit dans un journal
(/var/log/fleet-post-install-<date>.log).
USAGE
}

for arg in "$@"; do
    case "${arg}" in
        --luks=*)     NEW_LUKS_PASS="${arg#*=}" ;;
        --admin=*)    NEW_ADMIN_PASS="${arg#*=}" ;;
        --enrolltpm)  ENROLL_ONLY=1 ;;
        --notpm)      NO_TPM=1 ;;
        -h|--help)    usage; exit 0 ;;
        *) echo "Option inconnue : ${arg}" >&2; usage; exit 2 ;;
    esac
done
if [ "${ENROLL_ONLY}" -eq 1 ] && [ "${NO_TPM}" -eq 1 ]; then
    echo "Options contradictoires : --enrolltpm et --notpm." >&2; exit 2
fi

if [ "$(id -u)" -ne 0 ]; then
    echo "Élévation des privilèges (sudo)…"
    exec sudo -- "$0" "$@"
fi

# --- Journal + helpers d'affichage ------------------------------------------
LOG="/var/log/fleet-post-install-$(date +%Y%m%d_%H%M%S).log"
: > "${LOG}" 2>/dev/null || LOG="$(mktemp /tmp/fleet-post-install.XXXXXX.log 2>/dev/null || echo /dev/null)"
if [ -t 1 ]; then
    C_G=$'\e[32m'; C_R=$'\e[31m'; C_Y=$'\e[33m'; C_C=$'\e[36m'; C_B=$'\e[1m'; C_D=$'\e[2m'; C_0=$'\e[0m'
else C_G=''; C_R=''; C_Y=''; C_C=''; C_B=''; C_D=''; C_0=''; fi

log()  { printf '%s\n' "$*" >> "${LOG}" 2>/dev/null || true; }
ok()   { printf '   %s✓%s %s\n' "${C_G}" "${C_0}" "$*"; log "[ OK ] $*"; }
ko()   { printf '   %s✗%s %s\n' "${C_R}" "${C_0}" "$*"; log "[ KO ] $*"; }
warn() { printf '   %s!%s %s\n' "${C_Y}" "${C_0}" "$*"; log "[WARN] $*"; }
note() { printf '   %s· %s%s\n' "${C_D}" "$*" "${C_0}"; log "[ .. ] $*"; }
step() { printf '\n%s▸ %s%s\n' "${C_C}${C_B}" "$*" "${C_0}"; log ""; log "==== $* ===="; }
# Exécute une commande NON interactive en journalisant toute sa sortie.
run()  { log "\$ $*"; "$@" >> "${LOG}" 2>&1; }

header() {
    printf '\n%s╭───────────────────────────────────────────────╮%s\n' "${C_C}${C_B}" "${C_0}"
    printf '%s│  SZH · CSPS — post-installation                 │%s\n' "${C_C}${C_B}" "${C_0}"
    printf '%s╰───────────────────────────────────────────────╯%s\n' "${C_C}${C_B}" "${C_0}"
    printf '%s   journal détaillé : %s%s\n' "${C_D}" "${LOG}" "${C_0}"
    log "post-install $(date)  user=$(id -un)  args=$*"
}

# --- Détection LUKS ----------------------------------------------------------
luks_dev="$(blkid -t TYPE=crypto_LUKS -o device 2>/dev/null | head -n1 || true)"

secure_boot_word() {
    local s=""
    command -v bootctl >/dev/null 2>&1 && s="$(bootctl status 2>/dev/null | grep -i 'Secure Boot:' | head -n1)"
    [ -z "${s}" ] && command -v mokutil >/dev/null 2>&1 && s="$(mokutil --sb-state 2>/dev/null | head -n1)"
    log "SecureBoot: ${s:-?}"
    case "${s}" in
        *enabled*|*activé*) echo "on" ;;
        *disabled*|*désactivé*) echo "off" ;;
        *) echo "unknown" ;;
    esac
}

tpm_present()          { [ -e /dev/tpmrm0 ] || [ -e /dev/tpm0 ]; }
tpm_already_enrolled() { systemd-cryptenroll "${luks_dev}" 2>/dev/null | grep -qiw 'tpm2'; }

enroll_tpm() {
    local known_pass="${1:-}"
    [ -n "${luks_dev}" ] || { warn "Aucun volume LUKS → enrôlement TPM impossible."; return 1; }
    tpm_present          || { warn "Aucun TPM2 détecté (active-le dans l'UEFI) → enrôlement ignoré."; return 1; }
    tpm_already_enrolled && { ok "TPM déjà enrôlé."; return 0; }
    if [ -n "${known_pass}" ] && PASSWORD="${known_pass}" run systemd-cryptenroll "${luks_dev}" --tpm2-device=auto --tpm2-pcrs=7; then
        ok "TPM enrôlé (PCR 7)."; return 0
    fi
    note "Saisis la passphrase LUKS actuelle si demandée (« ${BOOTSTRAP_PASS} » au 1er usage) :"
    if systemd-cryptenroll "${luks_dev}" --tpm2-device=auto --tpm2-pcrs=7 2>>"${LOG}"; then
        ok "TPM enrôlé (PCR 7)."; return 0
    fi
    ko "Échec de l'enrôlement TPM (voir journal)."; return 1
}

reset_keyring() {
    local home kr
    home="$(getent passwd "${ADMIN_USER}" 2>/dev/null | cut -d: -f6)"
    [ -n "${home}" ] && kr="${home}/.local/share/keyrings" || return 0
    [ -d "${kr}" ] || return 0
    if [ -e "${kr}/login.keyring" ] || [ -e "${kr}/user.keystore" ]; then
        rm -f "${kr}/login.keyring" "${kr}/user.keystore"
        ok "Trousseau réinitialisé (recréé au prochain login avec le nouveau mot de passe)."
    fi
}

dump_initramfs_debug() {
    local out="/var/log/fleet-initramfs-debug-$(date +%Y%m%d_%H%M%S).log"
    {
        echo "=== Débogage initramfs $(date) ==="
        echo "--- rpm-ostree initramfs ---"; rpm-ostree initramfs 2>&1
        echo "--- stamp ---"; ls -l "${INITRAMFS_STAMP}" 2>&1
        echo "--- systemctl status ${INITRAMFS_SERVICE} ---"; systemctl status "${INITRAMFS_SERVICE}" --no-pager 2>&1
        echo "--- journalctl -u ${INITRAMFS_SERVICE} ---"; journalctl -u "${INITRAMFS_SERVICE}" --no-pager 2>&1
        echo "--- rpm-ostree status ---"; rpm-ostree status 2>&1
    } > "${out}" 2>&1 && warn "Détails de débogage : ${out}" || true
}

initramfs_is_enabled() {
    local s; s="$(rpm-ostree initramfs 2>/dev/null)"
    echo "${s}" | grep -qi 'enabled' && ! echo "${s}" | grep -qi 'disabled'
}

ensure_initramfs_local() {
    command -v rpm-ostree >/dev/null 2>&1 || { warn "rpm-ostree absent → étape initramfs ignorée."; return 0; }
    local service_ran=0; [ -e "${INITRAMFS_STAMP}" ] && service_ran=1
    if initramfs_is_enabled; then
        [ "${service_ran}" -eq 1 ] && ok "Régénération initramfs déjà activée par le service de 1er boot." \
                                   || ok "Régénération initramfs déjà active (activée manuellement)."
        return 0
    fi
    if [ "${service_ran}" -eq 1 ]; then
        warn "Le service ${INITRAMFS_SERVICE} a tourné mais la régénération n'est PAS active."
        dump_initramfs_debug
    else
        note "Activation de la régénération locale de l'initramfs…"
    fi
    if run rpm-ostree initramfs --enable; then
        ok "Régénération initramfs activée (effective au prochain redémarrage)."
    else
        ko "Échec de l'activation de l'initramfs (voir journal)."; dump_initramfs_debug
    fi
}

# =============================================================================
header "$@"

# --- Mode --enrolltpm : enrôlement seul --------------------------------------
if [ "${ENROLL_ONLY}" -eq 1 ]; then
    step "Secure Boot"
    case "$(secure_boot_word)" in
        on)  ok "Secure Boot activé." ;;
        off) warn "Secure Boot désactivé : enrôlement PCR 7 peu protecteur (active-le dans l'UEFI)." ;;
        *)   warn "État Secure Boot indéterminé." ;;
    esac
    step "Enrôlement TPM"
    enroll_tpm ""
    rc=$?
    step "Terminé"
    [ "${rc}" -eq 0 ] && ok "Enrôlement TPM effectué." || ko "Enrôlement TPM non effectué."
    note "Journal : ${LOG}"
    exit "${rc}"
fi

# --- Secure Boot -------------------------------------------------------------
step "Secure Boot"
case "$(secure_boot_word)" in
    on)  ok "Secure Boot activé." ;;
    off) warn "Secure Boot désactivé : l'enrôlement TPM (PCR 7) protège peu (active-le dans l'UEFI)." ;;
    *)   warn "État Secure Boot indéterminé." ;;
esac

# --- 1. TPM (avant le changement de clé LUKS) --------------------------------
step "Enrôlement TPM"
if [ "${NO_TPM}" -eq 1 ]; then
    note "--notpm : étape ignorée."
elif [ -z "${luks_dev}" ]; then
    warn "Aucun volume LUKS détecté → pas de TPM."
elif tpm_already_enrolled; then
    ok "TPM déjà enrôlé."
else
    enroll_tpm "${BOOTSTRAP_PASS}" || warn "Enrôlement TPM non effectué — on poursuit."
fi

# --- 2. Nouvelle passphrase LUKS ---------------------------------------------
step "Passphrase LUKS"
if [ -z "${luks_dev}" ]; then
    note "Aucun volume LUKS → étape ignorée."
elif [ -n "${NEW_LUKS_PASS}" ]; then
    if cryptsetup luksAddKey "${luks_dev}" \
            --key-file <(printf '%s' "${BOOTSTRAP_PASS}") \
            <(printf '%s' "${NEW_LUKS_PASS}") >>"${LOG}" 2>&1; then
        ok "Nouvelle passphrase LUKS ajoutée."
    else
        ko "Échec de l'ajout LUKS (passphrase d'amorçage incorrecte ?). Abandon."; note "Journal : ${LOG}"; exit 1
    fi
else
    note "Saisis une passphrase EXISTANTE (« ${BOOTSTRAP_PASS} »), puis la NOUVELLE :"
    if cryptsetup luksAddKey "${luks_dev}" 2>>"${LOG}"; then ok "Nouvelle passphrase LUKS ajoutée."
    else ko "Échec de l'ajout LUKS. Abandon."; exit 1; fi
fi

# --- 3. Mot de passe admin (+ trousseau) -------------------------------------
step "Mot de passe ${ADMIN_USER}"
admin_pw_changed=0
if [ -n "${NEW_ADMIN_PASS}" ]; then
    if printf '%s:%s\n' "${ADMIN_USER}" "${NEW_ADMIN_PASS}" | /usr/sbin/chpasswd >>"${LOG}" 2>&1; then
        ok "Mot de passe « ${ADMIN_USER} » changé."; admin_pw_changed=1
    else ko "Échec du changement de mot de passe « ${ADMIN_USER} »."; fi
else
    note "Saisis le nouveau mot de passe de « ${ADMIN_USER} » :"
    if passwd "${ADMIN_USER}"; then ok "Mot de passe « ${ADMIN_USER} » changé."; admin_pw_changed=1
    else ko "Mot de passe « ${ADMIN_USER} » non changé."; fi
fi
[ "${admin_pw_changed}" -eq 1 ] && reset_keyring

# --- 4. Initramfs local ------------------------------------------------------
step "Initramfs (splash + clavier suisse au boot)"
ensure_initramfs_local

# --- 5. Retrait de la passphrase d'amorçage ----------------------------------
step "Retrait de l'amorçage « ${BOOTSTRAP_PASS} »"
if [ -z "${luks_dev}" ]; then
    note "Aucun volume LUKS → rien à retirer."
else
    if systemd-cryptenroll "${luks_dev}" 2>/dev/null | grep -qiw 'tpm2'; then
        note "Token TPM présent : déverrouillage auto conservé."
    else
        warn "Pas de token TPM : seul un mot de passe déverrouillera (nouvelle passphrase valable)."
    fi
    if printf '%s' "${BOOTSTRAP_PASS}" | cryptsetup luksRemoveKey "${luks_dev}" >>"${LOG}" 2>&1; then
        ok "Passphrase d'amorçage « ${BOOTSTRAP_PASS} » retirée."
    else
        note "« ${BOOTSTRAP_PASS} » introuvable ou déjà retirée."
    fi
fi

# --- Récapitulatif -----------------------------------------------------------
step "Récapitulatif"
case "$(secure_boot_word)" in on) ok "Secure Boot : activé." ;; off) warn "Secure Boot : désactivé." ;; *) warn "Secure Boot : indéterminé." ;; esac
if [ -n "${luks_dev}" ] && systemd-cryptenroll "${luks_dev}" 2>/dev/null | grep -qiw 'tpm2'; then
    ok "TPM : enrôlé (déverrouillage auto)."
else
    warn "TPM : non enrôlé (déverrouillage par mot de passe)."
fi
[ -n "${luks_dev}" ] && run systemd-cryptenroll "${luks_dev}"   # détail des slots → journal
note "Conserve la nouvelle passphrase LUKS comme clé de secours."
note "Journal complet : ${LOG}"
printf '\n'
