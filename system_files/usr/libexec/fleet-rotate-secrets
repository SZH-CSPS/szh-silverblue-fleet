#!/usr/bin/env bash
# =============================================================================
#  fleet-rotate-secrets — moteur de rotation des secrets (TPM + LUKS + mot de passe admin).
#  Lancé via ~admin/change_password.sh (déposé au 1er boot). Voir --help.
#
#  Déroulé par défaut (en root) :
#    1. si le TPM n'est pas déjà enrôlé (et sauf --notpm) : enrôle le TPM2 (PCR 7)
#       AVANT toute modification de clé LUKS ;
#    2. ajoute une NOUVELLE passphrase LUKS, puis retire l'amorçage « changeme » ;
#    3. change le mot de passe du compte « admin ».
#  L'ajout LUKS précède la suppression → le disque n'est jamais sans clé valide.
# =============================================================================
set -uo pipefail

BOOTSTRAP_PASS="changeme"
ADMIN_USER="admin"
NEW_LUKS_PASS=""
NEW_ADMIN_PASS=""
NO_TPM=0
ENROLL_ONLY=0

usage() {
    cat <<'USAGE'
Usage : change_password.sh [options]

Rotation des secrets initiaux de la flotte (à lancer une fois, en tant qu'admin) :
  - enrôle le TPM2 (déverrouillage auto LUKS) s'il ne l'est pas déjà ;
  - ajoute une nouvelle passphrase LUKS et retire l'amorçage « changeme » ;
  - change le mot de passe du compte « admin ».

Options :
  --luks=VALEUR     Nouvelle passphrase LUKS. Absent  -> demandée interactivement.
  --admin=VALEUR    Nouveau mot de passe admin. Absent -> demandé interactivement.
  --enrolltpm       Enrôle UNIQUEMENT le TPM (aucun changement de mot de passe), puis sort.
  --notpm           Ne PAS toucher au TPM (ne fait que LUKS + mot de passe admin).
  -h, --help        Affiche cette aide.

Exemples :
  ./change_password.sh
  ./change_password.sh --luks=MaPhraseLUKS --admin=MonMotDePasse
  ./change_password.sh --enrolltpm
  ./change_password.sh --notpm --admin=MonMotDePasse

Notes :
  - L'enrôlement TPM demande la passphrase LUKS ACTUELLE (« changeme » au 1er usage) ;
    le script tente de la fournir automatiquement, sinon elle est demandée.
  - Passer un secret en argument le rend visible (ps, historique). Le script se relance
    via sudo s'il n'est pas lancé en root.
USAGE
}

# --- Analyse des arguments ---------------------------------------------------
for arg in "$@"; do
    case "${arg}" in
        --luks=*)     NEW_LUKS_PASS="${arg#*=}" ;;
        --admin=*)    NEW_ADMIN_PASS="${arg#*=}" ;;
        --enrolltpm)  ENROLL_ONLY=1 ;;
        --notpm)      NO_TPM=1 ;;
        -h|--help)    usage; exit 0 ;;
        *) echo "Option inconnue : ${arg}" >&2; usage; exit 2 ;;
    esac
done

if [ "${ENROLL_ONLY}" -eq 1 ] && [ "${NO_TPM}" -eq 1 ]; then
    echo "Options contradictoires : --enrolltpm et --notpm." >&2
    exit 2
fi

# --- Élévation root (en conservant les arguments) ----------------------------
if [ "$(id -u)" -ne 0 ]; then
    echo "Élévation des privilèges (sudo)…"
    exec sudo -- "$0" "$@"
fi

# --- Détection du volume LUKS ------------------------------------------------
luks_dev="$(blkid -t TYPE=crypto_LUKS -o device 2>/dev/null | head -n1 || true)"

# --- Fonctions TPM -----------------------------------------------------------
tpm_present() { [ -e /dev/tpmrm0 ] || [ -e /dev/tpm0 ]; }

tpm_already_enrolled() {
    # Vrai si un token/keyslot tpm2 existe déjà sur le volume.
    systemd-cryptenroll "${luks_dev}" 2>/dev/null | grep -qiw 'tpm2'
}

enroll_tpm() {
    # $1 (optionnel) : passphrase actuelle connue → enrôlement non interactif.
    local known_pass="${1:-}"
    if [ -z "${luks_dev}" ]; then
        echo "✗ Aucun volume LUKS détecté → enrôlement TPM impossible." >&2
        return 1
    fi
    if ! tpm_present; then
        echo "ℹ Aucun TPM2 détecté (/dev/tpmrm0). Active-le dans le firmware (UEFI). Enrôlement ignoré." >&2
        return 1
    fi
    if tpm_already_enrolled; then
        echo "ℹ TPM déjà enrôlé pour ${luks_dev} → rien à faire."
        return 0
    fi
    echo "→ Enrôlement TPM2 (PCR 7) pour ${luks_dev}…"
    if [ -n "${known_pass}" ]; then
        if PASSWORD="${known_pass}" systemd-cryptenroll "${luks_dev}" --tpm2-device=auto --tpm2-pcrs=7; then
            echo "✓ TPM enrôlé."; return 0
        fi
        echo "  (échec non interactif — nouvelle tentative avec saisie de la passphrase actuelle)"
    fi
    echo "  Saisir la passphrase LUKS ACTUELLE si demandée (« ${BOOTSTRAP_PASS} » au 1er usage) :"
    if systemd-cryptenroll "${luks_dev}" --tpm2-device=auto --tpm2-pcrs=7; then
        echo "✓ TPM enrôlé."; return 0
    fi
    echo "✗ Échec de l'enrôlement TPM." >&2
    return 1
}

secure_boot_state() {
    # Renvoie une ligne lisible décrivant l'état Secure Boot.
    if command -v bootctl >/dev/null 2>&1; then
        local line
        line="$(bootctl status 2>/dev/null | grep -i 'Secure Boot:' | head -n1 | sed 's/^[[:space:]]*//')"
        [ -n "${line}" ] && { echo "${line}"; return; }
    fi
    if command -v mokutil >/dev/null 2>&1; then
        local s; s="$(mokutil --sb-state 2>/dev/null | head -n1)"
        [ -n "${s}" ] && { echo "${s}"; return; }
    fi
    echo "état indéterminé (système non-UEFI ?)"
}

show_enrollments() {
    [ -n "${luks_dev}" ] || { echo "(aucun volume LUKS)"; return 0; }
    echo "Enrôlements LUKS sur ${luks_dev} :"
    systemd-cryptenroll "${luks_dev}" 2>/dev/null \
        || cryptsetup luksDump "${luks_dev}" 2>/dev/null | grep -iE 'tokens?|keyslot' \
        || true
}

INITRAMFS_SERVICE="fleet-initramfs-localize.service"
INITRAMFS_STAMP="/var/lib/fleet/initramfs-localized"

initramfs_is_enabled() {
    # Vrai si la régénération locale de l'initramfs est ACTIVE (et pas "disabled").
    local state; state="$(rpm-ostree initramfs 2>/dev/null)"
    echo "${state}" | grep -qi 'enabled' && ! echo "${state}" | grep -qi 'disabled'
}

dump_initramfs_debug() {
    # Collecte des infos de débogage (état rpm-ostree, service, journal) dans un fichier.
    local out="/var/log/fleet-initramfs-debug-$(date +%Y%m%d_%H%M%S).log"
    {
        echo "=== Débogage initramfs — $(date) ==="
        echo; echo "### rpm-ostree initramfs (état) ###"
        rpm-ostree initramfs 2>&1
        echo; echo "### stamp ${INITRAMFS_STAMP} ###"
        ls -l "${INITRAMFS_STAMP}" 2>&1
        echo; echo "### systemctl status ${INITRAMFS_SERVICE} ###"
        systemctl status "${INITRAMFS_SERVICE}" --no-pager 2>&1
        echo; echo "### journalctl -u ${INITRAMFS_SERVICE} ###"
        journalctl -u "${INITRAMFS_SERVICE}" --no-pager 2>&1
        echo; echo "### rpm-ostree status ###"
        rpm-ostree status 2>&1
    } > "${out}" 2>&1 && echo "  → Détails de débogage écrits dans : ${out}" \
                      || echo "  → (impossible d'écrire le fichier de débogage)" >&2
}

ensure_initramfs_local() {
    # Active la régénération LOCALE de l'initramfs (embarque le thème szh + le keymap suisse
    # de l'invite LUKS). Non interactif → fiable depuis ce script. Effectif au PROCHAIN
    # redémarrage. Idempotent. Notifie l'état et dump les infos de débogage si anomalie.
    command -v rpm-ostree >/dev/null 2>&1 || { echo "ℹ rpm-ostree absent → étape initramfs ignorée."; return 0; }

    local service_ran=0
    [ -e "${INITRAMFS_STAMP}" ] && service_ran=1

    if initramfs_is_enabled; then
        if [ "${service_ran}" -eq 1 ]; then
            echo "✓ Régénération initramfs déjà ACTIVÉE par le service de 1er boot (${INITRAMFS_SERVICE})."
        else
            echo "✓ Régénération initramfs déjà active (activée manuellement)."
        fi
        return 0
    fi

    # Pas active :
    if [ "${service_ran}" -eq 1 ]; then
        echo "⚠ ANOMALIE : le service ${INITRAMFS_SERVICE} a tourné (stamp présent) MAIS la"
        echo "  régénération n'est PAS active → le service n'a pas fait son job. Débogage :"
        dump_initramfs_debug
        echo "  → Tentative d'activation manuelle maintenant…"
    else
        echo "→ Le service de 1er boot n'a pas (encore) activé la régénération. Activation maintenant…"
    fi

    if rpm-ostree initramfs --enable; then
        echo "✓ Régénération initramfs activée — effective au PROCHAIN redémarrage."
    else
        echo "✗ Échec de l'activation (rpm-ostree occupé ?). Réessaie : sudo rpm-ostree initramfs --enable" >&2
        dump_initramfs_debug
    fi
}

reset_keyring() {
    # Le trousseau GNOME « login » est chiffré avec l'ANCIEN mot de passe ; un changement
    # via root (passwd/chpasswd) ne le ré-encode pas → il redemande l'ancien mot de passe.
    # Root n'ayant pas l'ancien mot de passe pour le ré-encoder, on réinitialise le trousseau
    # de connexion : GNOME le recrée, déverrouillé par le NOUVEAU mot de passe, à la session
    # suivante. ⚠ Les secrets éventuellement stockés dans ce trousseau sont perdus (OK pour
    # un compte d'administration fraîchement provisionné).
    local home kr
    home="$(getent passwd "${ADMIN_USER}" 2>/dev/null | cut -d: -f6)"
    [ -n "${home}" ] || return 0
    kr="${home}/.local/share/keyrings"
    [ -d "${kr}" ] || return 0
    if [ -e "${kr}/login.keyring" ] || [ -e "${kr}/user.keystore" ]; then
        rm -f "${kr}/login.keyring" "${kr}/user.keystore"
        echo "ℹ Trousseau de connexion (keyring) réinitialisé → recréé avec le NOUVEAU mot de"
        echo "  passe à la prochaine session (déconnexion/reconnexion d'« ${ADMIN_USER} »)."
    fi
}

echo "=== Rotation des secrets initiaux — SZH/CSPS ==="
echo

# --- Mode --enrolltpm : enrôlement seul, puis sortie -------------------------
if [ "${ENROLL_ONLY}" -eq 1 ]; then
    echo "Secure Boot : $(secure_boot_state)"
    echo
    enroll_tpm ""
    rc=$?
    echo
    echo "=== Récapitulatif ==="
    echo "Secure Boot : $(secure_boot_state)"
    show_enrollments
    echo
    [ "${rc}" -eq 0 ] && echo "Terminé (enrôlement TPM uniquement)." || echo "Enrôlement TPM non effectué." >&2
    exit "${rc}"
fi

# --- 0. Enrôlement TPM AVANT le changement de clé LUKS (sauf --notpm) --------
sb_state="$(secure_boot_state)"
echo "Secure Boot : ${sb_state}"
case "${sb_state}" in
    *enabled*|*activé*) echo "  ✓ Secure Boot actif → enrôlement TPM (PCR 7) pleinement utile." ;;
    *) echo "  ⚠ Secure Boot NON activé : l'enrôlement TPM lié à PCR 7 protège peu. Active" \
            "Secure Boot dans l'UEFI pour une vraie garantie, puis ré-enrôle (--enrolltpm)." ;;
esac
echo
if [ "${NO_TPM}" -eq 1 ]; then
    echo "ℹ --notpm : étape TPM ignorée."
elif [ -n "${luks_dev}" ]; then
    if tpm_already_enrolled; then
        echo "ℹ TPM déjà enrôlé → on ne ré-enrôle pas."
    else
        # changeme est encore valide à ce stade → enrôlement non interactif possible.
        enroll_tpm "${BOOTSTRAP_PASS}" || echo "⚠ Enrôlement TPM non effectué — on poursuit la rotation."
    fi
fi
echo

# --- 1. LUKS : ajout d'une nouvelle passphrase -------------------------------
if [ -z "${luks_dev}" ]; then
    echo "ℹ Aucun volume LUKS détecté → étape LUKS ignorée."
else
    echo "Volume chiffré : ${luks_dev}"
    echo "→ Ajout d'une nouvelle passphrase LUKS."
    if [ -n "${NEW_LUKS_PASS}" ]; then
        if cryptsetup luksAddKey "${luks_dev}" \
                --key-file <(printf '%s' "${BOOTSTRAP_PASS}") \
                <(printf '%s' "${NEW_LUKS_PASS}"); then
            echo "✓ Nouvelle passphrase LUKS ajoutée."
        else
            echo "✗ Échec de l'ajout (passphrase d'amorçage « ${BOOTSTRAP_PASS} » incorrecte ?). Abandon." >&2
            exit 1
        fi
    else
        echo "  (Saisir une passphrase EXISTANTE — « ${BOOTSTRAP_PASS} » —, puis la NOUVELLE.)"
        cryptsetup luksAddKey "${luks_dev}" || { echo "✗ Échec. Abandon." >&2; exit 1; }
    fi
fi
echo

# --- 2. Mot de passe du compte admin -----------------------------------------
echo "→ Mot de passe du compte « ${ADMIN_USER} »."
admin_pw_changed=0
if [ -n "${NEW_ADMIN_PASS}" ]; then
    if printf '%s:%s\n' "${ADMIN_USER}" "${NEW_ADMIN_PASS}" | /usr/sbin/chpasswd; then
        echo "✓ Mot de passe « ${ADMIN_USER} » changé."; admin_pw_changed=1
    else
        echo "✗ Échec du changement de mot de passe « ${ADMIN_USER} »." >&2
    fi
else
    if passwd "${ADMIN_USER}"; then admin_pw_changed=1; else echo "✗ Mot de passe « ${ADMIN_USER} » non changé." >&2; fi
fi
# Réinitialise le trousseau pour qu'il suive le NOUVEAU mot de passe (sinon il redemande l'ancien).
[ "${admin_pw_changed}" -eq 1 ] && reset_keyring
echo

# --- 3. Retrait de la passphrase d'amorçage « changeme » ---------------------
if [ -n "${luks_dev}" ]; then
    # Confirmation visuelle AVANT le retrait : vérifier qu'il reste de quoi déverrouiller
    # (idéalement un token tpm2 + la nouvelle passphrase).
    echo "→ Vérification avant retrait de « ${BOOTSTRAP_PASS} » :"
    show_enrollments
    if ! systemd-cryptenroll "${luks_dev}" 2>/dev/null | grep -qiw 'tpm2'; then
        echo "  ⚠ Aucun token TPM détecté : après retrait, seul un mot de passe permettra de"
        echo "    déverrouiller (pas de déverrouillage automatique). La NOUVELLE passphrase reste valable."
    fi
    echo
    echo "→ Retrait de la passphrase d'amorçage « ${BOOTSTRAP_PASS} »."
    if printf '%s' "${BOOTSTRAP_PASS}" | cryptsetup luksRemoveKey "${luks_dev}" 2>/dev/null; then
        echo "✓ Passphrase d'amorçage supprimée."
    else
        echo "ℹ « ${BOOTSTRAP_PASS} » introuvable ou déjà retirée — rien à faire."
    fi
fi
echo

# --- 4. Régénération locale de l'initramfs (splash szh + clavier suisse LUKS) -
ensure_initramfs_local
echo

# --- Récapitulatif final -----------------------------------------------------
echo "=== Récapitulatif ==="
echo "Secure Boot : $(secure_boot_state)"
show_enrollments
echo
echo "Terminé. Conservez la nouvelle passphrase LUKS comme clé de secours."
