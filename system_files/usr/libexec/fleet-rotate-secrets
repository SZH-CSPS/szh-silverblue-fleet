#!/usr/bin/env bash
# =============================================================================
#  fleet-rotate-secrets — moteur de rotation des secrets (LUKS + mot de passe admin).
#  Lancé via ~admin/change_password.sh (déposé au 1er boot). Voir --help.
#
#  Étapes (en root) :
#    1. ajoute une NOUVELLE passphrase LUKS, puis retire l'amorçage « changeme » ;
#    2. change le mot de passe du compte « admin ».
#  L'ajout précède la suppression → le disque n'est jamais sans clé valide.
# =============================================================================
set -uo pipefail

BOOTSTRAP_PASS="changeme"
ADMIN_USER="admin"
NEW_LUKS_PASS=""
NEW_ADMIN_PASS=""

usage() {
    cat <<'USAGE'
Usage : change_password.sh [--luks=NOUVELLE_PASSPHRASE] [--admin=NOUVEAU_MDP] [--help]

Rotation des secrets initiaux de la flotte (à lancer une fois, en tant qu'admin) :
  1. ajoute une nouvelle passphrase LUKS, puis retire la passphrase d'amorçage « changeme » ;
  2. change le mot de passe du compte « admin ».

Options :
  --luks=VALEUR     Nouvelle passphrase LUKS. Absent  -> demandée interactivement.
  --admin=VALEUR    Nouveau mot de passe admin. Absent -> demandé interactivement.
  -h, --help        Affiche cette aide.

Exemples :
  ./change_password.sh
  ./change_password.sh --luks=MaPhraseLUKS --admin=MonMotDePasse
  ./change_password.sh --admin=MonMotDePasse

Note sécurité : passer un secret en argument le rend visible (ps, historique du shell).
Le script se relance automatiquement via sudo s'il n'est pas lancé en root.
USAGE
}

# --- Analyse des arguments ---------------------------------------------------
for arg in "$@"; do
    case "${arg}" in
        --luks=*)  NEW_LUKS_PASS="${arg#*=}" ;;
        --admin=*) NEW_ADMIN_PASS="${arg#*=}" ;;
        -h|--help) usage; exit 0 ;;
        *) echo "Option inconnue : ${arg}" >&2; usage; exit 2 ;;
    esac
done

# --- Élévation root (en conservant les arguments) ----------------------------
if [ "$(id -u)" -ne 0 ]; then
    echo "Élévation des privilèges (sudo)…"
    exec sudo -- "$0" "$@"
fi

echo "=== Rotation des secrets initiaux — SZH/CSPS ==="
echo

# --- 1. LUKS : ajout d'une nouvelle passphrase -------------------------------
luks_dev="$(blkid -t TYPE=crypto_LUKS -o device 2>/dev/null | head -n1 || true)"
if [ -z "${luks_dev}" ]; then
    echo "ℹ Aucun volume LUKS détecté → étape LUKS ignorée."
else
    echo "Volume chiffré : ${luks_dev}"
    echo "→ Ajout d'une nouvelle passphrase LUKS."
    if [ -n "${NEW_LUKS_PASS}" ]; then
        if cryptsetup luksAddKey "${luks_dev}" \
                --key-file <(printf '%s' "${BOOTSTRAP_PASS}") \
                <(printf '%s' "${NEW_LUKS_PASS}"); then
            echo "✓ Nouvelle passphrase LUKS ajoutée."
        else
            echo "✗ Échec de l'ajout (passphrase d'amorçage « ${BOOTSTRAP_PASS} » incorrecte ?). Abandon." >&2
            exit 1
        fi
    else
        echo "  (Saisir une passphrase EXISTANTE — « ${BOOTSTRAP_PASS} » —, puis la NOUVELLE.)"
        cryptsetup luksAddKey "${luks_dev}" || { echo "✗ Échec. Abandon." >&2; exit 1; }
    fi
fi
echo

# --- 2. Mot de passe du compte admin -----------------------------------------
echo "→ Mot de passe du compte « ${ADMIN_USER} »."
if [ -n "${NEW_ADMIN_PASS}" ]; then
    if printf '%s:%s\n' "${ADMIN_USER}" "${NEW_ADMIN_PASS}" | /usr/sbin/chpasswd; then
        echo "✓ Mot de passe « ${ADMIN_USER} » changé."
    else
        echo "✗ Échec du changement de mot de passe « ${ADMIN_USER} »." >&2
    fi
else
    passwd "${ADMIN_USER}" || echo "✗ Mot de passe « ${ADMIN_USER} » non changé." >&2
fi
echo

# --- 3. Retrait de la passphrase d'amorçage « changeme » ---------------------
if [ -n "${luks_dev}" ]; then
    echo "→ Retrait de la passphrase d'amorçage « ${BOOTSTRAP_PASS} »."
    if printf '%s' "${BOOTSTRAP_PASS}" | cryptsetup luksRemoveKey "${luks_dev}" 2>/dev/null; then
        echo "✓ Passphrase d'amorçage supprimée."
    else
        echo "ℹ « ${BOOTSTRAP_PASS} » introuvable ou déjà retirée — rien à faire."
    fi
fi
echo
echo "=== Terminé. Conservez la nouvelle passphrase LUKS comme clé de secours. ==="
