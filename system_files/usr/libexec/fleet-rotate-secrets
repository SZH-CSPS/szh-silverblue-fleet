#!/usr/bin/env bash
# =============================================================================
#  fleet-rotate-secrets — assistant de rotation des secrets initiaux de la flotte.
#  Lancé par le raccourci "Rotation des secrets" du bureau d'admin (dans un terminal),
#  ou directement (en root) pour un usage non interactif.
#
#  Étapes (en root) :
#    1. ajoute une NOUVELLE passphrase LUKS ;
#    2. change le mot de passe du compte ADMIN ;
#    3. retire l'ANCIENNE passphrase d'amorçage "changeme".
#  L'ajout précède la suppression → le disque n'est jamais sans clé valide.
#  En cas de réussite, le raccourci du bureau se supprime (opération unique).
#
#  PARAMÈTRES (variables) — pré-remplir pour un fonctionnement NON interactif :
#    NEW_LUKS_PASS   : nouvelle passphrase LUKS. Si vide → demandée à l'utilisateur.
#    NEW_ADMIN_PASS  : nouveau mot de passe d'admin. Si vide → demandé à l'utilisateur.
#  Surchargeables par variable d'environnement de même nom, p. ex. :
#    sudo NEW_LUKS_PASS=... NEW_ADMIN_PASS=... /usr/libexec/fleet-rotate-secrets
# =============================================================================
set -uo pipefail

# --- Paramètres (éditer ici, ou fournir via l'environnement) -----------------
NEW_LUKS_PASS="${NEW_LUKS_PASS:-}"
NEW_ADMIN_PASS="${NEW_ADMIN_PASS:-}"

# Compte et passphrase d'amorçage (constantes de la flotte).
ADMIN_USER="admin"
BOOTSTRAP_PASS="changeme"

# --- Élévation : relancer en root si besoin (en préservant les paramètres) ----
if [ "$(id -u)" -ne 0 ]; then
    echo "Élévation des privilèges (sudo)…"
    exec sudo --preserve-env=NEW_LUKS_PASS,NEW_ADMIN_PASS -- "$0" "$@"
fi

echo "==================================================================="
echo "  Rotation des secrets initiaux — SZH/CSPS"
echo "==================================================================="
echo

# --- 1. LUKS : ajout d'une nouvelle passphrase -------------------------------
luks_dev="$(blkid -t TYPE=crypto_LUKS -o device 2>/dev/null | head -n1 || true)"

if [ -z "${luks_dev}" ]; then
    echo "ℹ Aucun volume LUKS détecté → étape LUKS ignorée."
else
    echo "Volume chiffré détecté : ${luks_dev}"
    echo "→ Étape 1/3 : ajout d'une nouvelle passphrase LUKS."
    if [ -n "${NEW_LUKS_PASS}" ]; then
        # Non interactif : autorise avec la passphrase d'amorçage, ajoute la nouvelle.
        if cryptsetup luksAddKey "${luks_dev}" \
                --key-file <(printf '%s' "${BOOTSTRAP_PASS}") \
                <(printf '%s' "${NEW_LUKS_PASS}"); then
            echo "✓ Nouvelle passphrase LUKS ajoutée (non interactif)."
        else
            echo "✗ Échec de l'ajout (passphrase d'amorçage incorrecte ?). Abandon." >&2
            read -rp "Entrée pour fermer…" _ || true
            exit 1
        fi
    else
        echo "  (Saisir une passphrase EXISTANTE — « ${BOOTSTRAP_PASS} » —, puis la NOUVELLE.)"
        if ! cryptsetup luksAddKey "${luks_dev}"; then
            echo "✗ Échec de l'ajout de la nouvelle passphrase. Abandon." >&2
            read -rp "Entrée pour fermer…" _ || true
            exit 1
        fi
        echo "✓ Nouvelle passphrase LUKS ajoutée."
    fi
fi
echo

# --- 2. Mot de passe du compte admin -----------------------------------------
echo "→ Étape 2/3 : nouveau mot de passe pour « ${ADMIN_USER} »."
if [ -n "${NEW_ADMIN_PASS}" ]; then
    if printf '%s:%s\n' "${ADMIN_USER}" "${NEW_ADMIN_PASS}" | /usr/sbin/chpasswd; then
        echo "✓ Mot de passe « ${ADMIN_USER} » changé (non interactif)."
    else
        echo "✗ Échec du changement du mot de passe « ${ADMIN_USER} »." >&2
    fi
else
    if ! passwd "${ADMIN_USER}"; then
        echo "✗ Le mot de passe « ${ADMIN_USER} » n'a pas été changé." >&2
    fi
fi
echo

# --- 3. Retrait de la passphrase d'amorçage "changeme" -----------------------
if [ -n "${luks_dev}" ]; then
    echo "→ Étape 3/3 : retrait de la passphrase d'amorçage « ${BOOTSTRAP_PASS} »."
    if printf '%s' "${BOOTSTRAP_PASS}" | cryptsetup luksRemoveKey "${luks_dev}" 2>/dev/null; then
        echo "✓ Passphrase d'amorçage supprimée."
    else
        echo "ℹ « ${BOOTSTRAP_PASS} » introuvable ou déjà retirée — rien à faire."
    fi
fi
echo

# --- Auto-suppression du raccourci (opération unique) ------------------------
launcher="/home/${ADMIN_USER}/Desktop/fleet-rotate-secrets.desktop"
[ -e "${launcher}" ] && rm -f "${launcher}" && echo "Raccourci du bureau retiré (opération unique)."

echo
echo "Terminé. Conservez la nouvelle passphrase LUKS comme clé de secours."
read -rp "Entrée pour fermer…" _ || true
