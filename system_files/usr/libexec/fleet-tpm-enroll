#!/usr/bin/env bash
# =============================================================================
#  fleet-tpm-enroll — CLI ADMIN : lie le déverrouillage LUKS au TPM2 (+ PIN).
#
#  Voie normale pour les utilisateurs : l'assistant graphique au premier login
#  (fleet-tpm-pin-setup, autostart). Ce CLI sert aux admins (SSH, dépannage,
#  ré-enrôlement après changement de firmware/Secure Boot).
#
#  PRÉREQUIS : disque DÉJÀ chiffré LUKS (choisi à l'installation — docs/06).
#  Ajoute un token TPM2 (PCR 7 = état Secure Boot) à l'en-tête LUKS existant,
#  AVEC PIN par défaut (politique de flotte). --no-pin pour un déverrouillage
#  entièrement automatique (déconseillé sur laptop : un voleur de la machine
#  complète arrive alors directement à l'écran de connexion).
#
#  Usage :  sudo fleet-tpm-enroll [--no-pin]
#  Conserve TOUJOURS la phrase de passe LUKS : elle reste le moyen de secours.
# =============================================================================
set -euo pipefail

with_pin="yes"
[ "${1:-}" = "--no-pin" ] && with_pin="no"

if [ "$(id -u)" -ne 0 ]; then
    echo "Lance ce script en root :  sudo fleet-tpm-enroll [--no-pin]" >&2
    exit 1
fi

# 1. Trouver la partition LUKS.
dev="$(blkid -t TYPE=crypto_LUKS -o device | head -1 || true)"
if [ -z "$dev" ]; then
    echo "Aucune partition LUKS trouvée — le disque est-il chiffré ? (voir docs/06)" >&2
    exit 1
fi
echo "Partition LUKS détectée : $dev"

# 2. Vérifier la présence d'un TPM2.
if [ ! -e /dev/tpmrm0 ] && [ ! -e /dev/tpm0 ]; then
    echo "Aucun TPM2 détecté (/dev/tpmrm0). Active le TPM dans le firmware (UEFI)." >&2
    exit 1
fi

# 3. Enrôler le TPM2, lié à PCR 7 (état Secure Boot — stable aux MAJ du noyau).
#    PCR 7 n'a de valeur que si Secure Boot est ACTIVÉ (voir docs/06).
#    --wipe-slot=tpm2 : remplace un éventuel enrôlement TPM2 précédent (pas de
#    slots dupliqués lors d'un ré-enrôlement).
echo "Enrôlement TPM2 (PCR 7, PIN: ${with_pin})… la phrase de passe LUKS actuelle va être demandée."
systemd-cryptenroll --wipe-slot=tpm2 \
    --tpm2-device=auto --tpm2-pcrs=7 --tpm2-with-pin="${with_pin}" "$dev"

mkdir -p /var/lib/fleet
touch /var/lib/fleet/tpm-enrolled

cat <<EON

✓ Enrôlement effectué pour : $dev
  • Redémarre pour tester le déverrouillage (PIN: ${with_pin}).
  • La phrase de passe LUKS reste valable (secours indispensable — ne la perds pas).
  • Si Secure Boot / le firmware change, le TPM peut refuser : déverrouille à la phrase
    de passe, puis relance « sudo fleet-tpm-enroll » pour ré-enrôler.
  • Lister les enrôlements :  systemd-cryptenroll "$dev"   (ou : cryptsetup luksDump "$dev")
EON
